# .env.example
# --- Global Settings ---
DOMAIN_NAME=localhost
TIMEZONE=UTC

# --- OpenClaw Model Auth Inputs ---
# OpenAI and Anthropic are configured via OAuth/setup-token flows (not API keys)
# through `./scripts/openclaw-web-auth-setup.sh`.
# Gemini is configured via interactive OAuth (google-gemini-cli), not API key.
# If you use `scripts/gemini-token-refresh.sh`, also set:
# GEMINI_OAUTH_CLIENT_ID=
# GEMINI_OAUTH_CLIENT_SECRET=
KILOCODE_API_KEY=
OLLAMA_API_KEY=ollama-local

# --- n8n Settings ---
N8N_ENCRYPTION_KEY=random_secure_string
N8N_EMAIL=you@example.com
N8N_PASSWORD=replace_with_n8n_password

# --- Google OAuth (for n8n Gmail Trigger + Google Workspace MCP) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Microsoft 365 / Outlook (for ms-365-mcp-server) ---
# Create an Azure AD app registration with Mail.Read, Mail.Send, Calendars.Read
# See: https://github.com/Softeria/ms-365-mcp-server#readme
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT_ID=common

# --- OpenClaw Settings ---
# Generate long random values before production use.
OPENCLAW_GATEWAY_TOKEN=replace_with_gateway_token
OPENCLAW_HOOKS_TOKEN=replace_with_dedicated_hooks_token
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest
OPENCLAW_GATEWAY_BIND=loopback
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790
OPENCLAW_ALLOW_INSECURE_PRIVATE_WS=
N8N_OLLAMA_MODEL_PRIMARY=glm-4.7-flash
N8N_OLLAMA_MODEL_FALLBACK=glm-4.7-flash
N8N_ANTHROPIC_MODEL_PRIMARY=claude-haiku-4-5-20251001

# --- Google Places (goplaces hardening) ---
GOOGLE_PLACES_API_KEY=
GOPLACES_ENFORCE_PROXY=1
GOPLACES_HTTPS_PROXY=http://host.docker.internal:3128
GOPLACES_ALLOW_BASE_URL_OVERRIDE=0
GOPLACES_ALLOW_ANY_PROXY=0
