# .env.example
# --- Global Settings ---
DOMAIN_NAME=localhost
TIMEZONE=UTC

# --- LLM API Keys (Required for OpenClaw) ---
OPENAI_API_KEY=your_openai_key
ANTHROPIC_API_KEY=your_anthropic_key

# --- n8n Settings ---
N8N_ENCRYPTION_KEY=random_secure_string

# --- OpenClaw Settings ---
# Set to 1 to enable extra sandboxing for code execution
OPENCLAW_SANDBOX=1
