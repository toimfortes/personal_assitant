{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://email-master.local/schemas/n8n-workflow.schema.json",
  "title": "n8n Workflow Minimal Contract",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "name",
    "nodes",
    "connections"
  ],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 3
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "name",
          "type",
          "typeVersion",
          "position"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string",
            "minLength": 3
          },
          "typeVersion": {
            "type": [
              "integer",
              "number"
            ]
          },
          "position": {
            "type": "array",
            "minItems": 2,
            "maxItems": 2,
            "items": {
              "type": [
                "integer",
                "number"
              ]
            }
          },
          "parameters": {
            "type": "object"
          }
        }
      }
    },
    "connections": {
      "type": "object",
      "minProperties": 1
    }
  }
}
